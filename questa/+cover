    class AES_monitor extends uvm_monitor;
                 typedef uvm_component_registry #(AES_monitor,"AES_monitor") type_id;
     static function type_id get_type();
       return type_id::get();
     endfunction     virtual function uvm_object_wrapper get_object_type();
       return type_id::get();
     endfunction         const static string type_name = "AES_monitor";
     virtual function string get_type_name ();
       return type_name;
     endfunction   

        AES_seq_item seq_item;
        virtual AES_intf AES_vif;

        uvm_analysis_port#(AES_seq_item) ap;

        function new(string name = "AES_monitor", uvm_component parent = null);
            super.new(name, parent);
        endfunction

        function void build_phase (uvm_phase phase);
            super.build_phase(phase);
            seq_item = AES_seq_item::type_id::create("seq_item", this);
            ap = new("ap", this);

            if (!uvm_config_db#(virtual AES_intf)::get(this, "", "AES_vif", AES_vif)) begin
                     begin
       if (uvm_report_enabled(UVM_NONE,UVM_FATAL,"AES_MONITOR"))         uvm_report_fatal ("AES_MONITOR", "Virtual interface not found in config DB", UVM_NONE, "../UVM/AES_monitor.sv", 26);
     end

            end else begin
                     begin
       if (uvm_report_enabled(UVM_LOW,UVM_INFO,"AES_MONITOR"))         uvm_report_info ("AES_MONITOR", "Virtual interface found and set in config DB", UVM_LOW, "../UVM/AES_monitor.sv", 28);
     end

            end
        endfunction

        task run_phase (uvm_phase phase);
            super.run_phase(phase);
            forever begin
                repeat(2)@(AES_vif.cb);
                seq_item.rst_n <= AES_vif.rst_n;
                seq_item.plain_text <= AES_vif.plain_text;
                seq_item.cipher_key <= AES_vif.cipher_key;
                seq_item.valid_in <= AES_vif.valid_in;
                seq_item.valid_out <= AES_vif.valid_out;
                seq_item.cipher_text <= AES_vif.cipher_text;
                seq_item.enc_dec <= AES_vif.enc_dec;
                #1step ap.write(seq_item);
            end
        endtask

    endclass : AES_monitor


