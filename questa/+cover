                bins valid_in_transition_back = (1 => 0) ;
            }
            valid_out_cp : coverpoint seq_item.valid_out {
                bins valid_out_0 = {0};
                bins valid_out_1 = {1};
                bins valid_out_transition = (0 => 1) ;
