                bins plain_text_pattern = {128'hFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF};
                
                
            }
            
            
            
            
            
            
            key_cp : coverpoint seq_item.cipher_key {
                bins key_0 = {128'h0};
                bins key_non_zero = {[128'h1 : 128'hFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFFF]};
